{
    "_notes": [
        "Slimmable WaveNet: channel-slicing training. No head 1x1, FiLM, condition_dsp, or groups > 1."
    ],
    "net": {
        "name": "WaveNet",
        "config": {
            "layers_configs": [
                {
                    "condition_size": 1,
                    "input_size": 1,
                    "channels": 12,
                    "head_size": 1,
                    "kernel_size": 6,
                    "dilations": [
                        1,
                        5,
                        29,
                        97,
                        227,
                        1,
                        5,
                        29,
                        97,
                        227,
                        1,
                        5,
                        29,
                        97,
                        227
                    ],
                    "activation": "LeakyReLU",
                    "head_bias": true
                }
            ],
            "head_scale": 0.01
        }
    },
    "optimizer": {
        "lr": 0.004
    },
    "lr_scheduler": {
        "class": "ExponentialLR",
        "kwargs": {
            "gamma": 0.993
        }
    }
}