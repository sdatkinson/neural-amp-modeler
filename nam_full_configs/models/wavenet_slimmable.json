{
    "_notes": [
        "Slimmable WaveNet: channel-slicing training. No head 1x1, FiLM, condition_dsp, or groups > 1."
    ],
    "net": {
        "name": "WaveNet",
        "config": {
            "layers_configs": [
                {
                    "condition_size": 1,
                    "input_size": 1,
                    "channels": 16,
                    "head_size": 8,
                    "kernel_size": 3,
                    "dilations": [
                        1,
                        2,
                        4,
                        8,
                        16,
                        32,
                        64,
                        128,
                        256,
                        512
                    ],
                    "activation": "Tanh",
                    "head_bias": false,
                    "slimmable": {}
                },
                {
                    "condition_size": 1,
                    "input_size": 16,
                    "channels": 8,
                    "head_size": 1,
                    "kernel_size": 3,
                    "dilations": [
                        1,
                        2,
                        4,
                        8,
                        16,
                        32,
                        64,
                        128,
                        256,
                        512
                    ],
                    "activation": "Tanh",
                    "head_bias": true,
                    "slimmable": {}
                }
            ],
            "head_scale": 0.02
        }
    },
    "optimizer": {
        "lr": 0.004
    },
    "lr_scheduler": {
        "class": "ExponentialLR",
        "kwargs": {
            "gamma": 0.993
        }
    }
}
